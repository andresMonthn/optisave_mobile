{
  "expo": {
    "name": "OptiSave",
    "slug": "optisave-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Optisave_LgL-noBg.png",
    "scheme": "optisavemobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/Optisave_LgL-noBg.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Optisave_LgL-noBg.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/Optisave_LgL-noBg.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Optisave_LgL-noBg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/Optisave_LgL-noBg.png",
          "imageWidth": 180
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
