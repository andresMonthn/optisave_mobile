# ---------------------------------------------------------------------------
# OptiSave Mobile — environment variables
# ---------------------------------------------------------------------------
# 1. Copy this file to `.env`   (cp .env.example .env)
# 2. Fill in the two values from your Supabase project:
#      Supabase Dashboard → Project Settings → API
#         • Project URL          -> EXPO_PUBLIC_SUPABASE_URL
#         • Project API keys → anon / publishable -> EXPO_PUBLIC_SUPABASE_ANON_KEY
# 3. Restart the dev server after changing .env (values are inlined at build time):
#      npx expo start -c
#
# Until these are set the app runs on local mock data (no backend required).
# Both values are safe to ship in the client bundle — they are protected by
# Row Level Security. NEVER put the service_role key here.
# ---------------------------------------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
